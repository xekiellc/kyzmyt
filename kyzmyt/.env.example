# Kyzmyt — Environment Variables
# Set all of these in your Netlify dashboard under Site Settings → Environment Variables
# Never commit real values to GitHub

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# ⚠️ SERVICE_ROLE_KEY is only used in Netlify functions — NEVER expose client-side

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
# OR for testing:
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Pricing IDs (create these in Stripe Dashboard → Products)
STRIPE_PRICE_MEMBER=price_...       # $29/month Member plan
STRIPE_PRICE_CONCIERGE=price_...    # $299/month Concierge plan

# ── Checkr (Background Checks) ───────────────────────────────────────────────
CHECKR_API_KEY=live_...
# OR for testing:
CHECKR_API_KEY=test_...
CHECKR_WEBHOOK_SECRET=...
# Set webhook URL in Checkr dashboard to: https://your-site.netlify.app/.netlify/functions/checkr-webhook
# Webhook events to enable:
#   report.completed
#   report.disputed
#   candidate.created

# ── Plaid (Financial Verification) ───────────────────────────────────────────
PLAID_CLIENT_ID=...
PLAID_SECRET=...
PLAID_ENV=sandbox
# Change to 'production' when ready to go live

# ── Twilio (Safety Check-ins + SMS) ──────────────────────────────────────────
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=...
TWILIO_PHONE_NUMBER=+1...
# Configure SMS reply webhook in Twilio console:
# POST https://your-site.netlify.app/.netlify/functions/sms-reply

# ── Resend (Transactional Email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...
# Verify your domain at resend.com and configure hello@kyzmyt.com

# ── Anthropic / Claude API (Compatibility AI + Icebreakers) ──────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Site URL ──────────────────────────────────────────────────────────────────
SITE_URL=https://kyzmyt.com
# During development: https://your-netlify-subdomain.netlify.app

# ── Spotify (Optional — Profile Soundtrack) ───────────────────────────────────
SPOTIFY_CLIENT_ID=...
SPOTIFY_CLIENT_SECRET=...

# ══════════════════════════════════════════════════════════════════════════════
# SETUP CHECKLIST
# ══════════════════════════════════════════════════════════════════════════════

# 1. SUPABASE
#    - Create new project at supabase.com
#    - Run supabase-schema.sql in SQL Editor
#    - Enable Realtime for: messages, matches, likes, stories
#    - Create storage buckets: profile-photos (public), stories (public)
#    - Enable Google OAuth: Authentication → Providers → Google
#    - Set Site URL and redirect URLs in Auth settings

# 2. STRIPE
#    - Create account at stripe.com
#    - Create products: Member ($29/mo), Concierge ($299/mo), ID Verify ($5), Background Check ($30), Financial Badge ($12)
#    - Set up webhooks pointing to /.netlify/functions/stripe-webhook
#    - Enable webhook events:
#      checkout.session.completed
#      identity.verification_session.verified
#      identity.verification_session.requires_input
#      customer.subscription.deleted

# 3. CHECKR
#    - Create account at checkr.com
#    - Apply for API access (requires business verification)
#    - Use test package 'driver_pro' in sandbox
#    - Set webhook to /.netlify/functions/checkr-webhook

# 4. PLAID
#    - Create account at plaid.com/products/assets
#    - Sandbox available immediately
#    - Production requires business verification

# 5. TWILIO
#    - Create account at twilio.com
#    - Get a phone number
#    - Set up SMS webhook for incoming messages: /.netlify/functions/sms-reply

# 6. RESEND
#    - Create account at resend.com
#    - Add and verify your domain
#    - Configure hello@kyzmyt.com

# 7. NETLIFY
#    - Connect GitHub repo to Netlify
#    - Set all environment variables above
#    - Build command: (none — static site)
#    - Publish directory: .
#    - Functions directory: netlify/functions

# 8. DOMAIN
#    - Point kyzmyt.com DNS to Netlify
#    - Enable Netlify SSL
#    - Update SITE_URL env variable
